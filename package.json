{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "tsx watch server/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.server.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node dist-server/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.29.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.10",
    "razorpay": "^2.9.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-redux": "^9.3.0",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "twilio": "^6.0.2",
    "vite": "^6.2.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
